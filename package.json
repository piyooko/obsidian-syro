{
    "name": "syro",
    "version": "0.0.3",
    "description": "Seamless spaced repetition, flashcards, and incremental reading workflows. A stylized, modern interface alternative to Anki for your plain-text knowledge base.",
    "main": "build/main.js",
    "scripts": {
        "build": "node esbuild.config.mjs production",
        "dev": "node esbuild.config.mjs",
        "format": "pnpm prettier --write . && pnpm eslint src/ tests/ --fix",
        "lint": "pnpm prettier --check . && pnpm eslint src/ tests/",
        "test": "jest",
        "validate": "concurrently --kill-others-on-fail -g -p \"[{name}]\" -n \"format,lint,test\" \"pnpm:format\" \"pnpm:lint\" \"pnpm:test\"",
        "precommit-msg": "echo 'Pre-commit checks...'",
        "changelog": "pnpm auto-changelog --template=compact --package && pnpm prettier --write docs/docs/changelog.md",
        "css:report": "node scripts/css-report.mjs",
        "knip": "knip --no-config-hints",
        "knip:production": "knip --production --no-config-hints"
    },
    "keywords": [
        "obsidian",
        "syro",
        "spaced-repetition",
        "flashcards",
        "incremental-learning"
    ],
    "author": "piyooko",
    "license": "MIT",
    "devDependencies": {
        "@popperjs/core": "^2.11.8",
        "@types/jest": "^29.5.12",
        "@types/node": "^20.16.2",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@types/vhtml": "^2.2.9",
        "@typescript-eslint/eslint-plugin": "^6.21.0",
        "@typescript-eslint/parser": "^6.21.0",
        "auto-changelog": "^2.5.0",
        "autoprefixer": "^10.4.23",
        "builtin-modules": "^3.3.0",
        "concurrently": "^9.2.1",
        "deepcopy": "^2.1.0",
        "esbuild": "~0.19.12",
        "eslint": "^8.57.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "jest-expect-message": "^1.1.3",
        "knip": "^5.86.0",
        "moment": "^2.30.1",
        "obsidian": "^1.6.6",
        "postcss": "^8.5.6",
        "postcss-import": "^15.1.0",
        "prettier": "^3.3.3",
        "tailwindcss": "^3.4.0",
        "ts-fsrs": "^5.2.1",
        "ts-jest": "^29.2.5",
        "tslib": "2.6.1",
        "typescript": "5.1.6",
        "vhtml": "^2.2.0"
    },
    "dependencies": {
        "@codemirror/state": "^6.5.0",
        "@codemirror/view": "^6.38.6",
        "chart.js": "^4.4.8",
        "clozecraft": "^0.4.0",
        "framer-motion": "^12.23.26",
        "lucide-react": "^0.562.0",
        "minimatch": "^10.0.1",
        "pagerank.js": "^1.0.2",
        "preact": "^10.27.2",
        "react": "^19.2.3",
        "react-dom": "^19.2.3"
    },
    "pre-commit": [
        "precommit-msg",
        "validate"
    ],
    "packageManager": "pnpm@9.10.0",
    "engines": {
        "pnpm": ">=9.10.0"
    },
    "engineStrict": true
}
